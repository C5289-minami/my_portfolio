---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>Minami's Portfolio</title>
  <style>
    body { font-family: sans-serif; text-align: center; padding-top: 100px; background: #111; color: white; }
    h1 { font-size: 3rem; margin-bottom: 0.5rem; }
    p { color: #888; margin-bottom: 2rem; }
    .nav-links a {
      display: inline-block;
      margin: 0 15px;
      color: #4f39fa;
      text-decoration: none;
      font-weight: bold;
      border: 1px solid #4f39fa;
      padding: 10px 20px;
      border-radius: 5px;
      transition: 0.3s;
    }
    .nav-links a:hover { background: #4f39fa; color: white; }
  </style>
</head>
<body>
  <h1>Minami's Portfolio</h1>
  <p>19-year-old Engineer / Creator</p>
  
  <nav class="nav-links">
    <a href="/my_portfolio/blog">Blog (制作ログ)</a>
    <a href="/my_portfolio/about">About Me</a>
  </nav>
</body>
</html>
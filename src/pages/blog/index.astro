---
import Layout from '../layouts/Layout.astro';
import { client } from "../../lib/microcms";

// microCMSから記事一覧を取得
const response = await client.get({
  endpoint: "blog",
  queries: { fields: 'id,title,eyecatch' }
}).catch(() => ({ contents: [] }));

const posts = response.contents;
---

<Layout title="制作ログ一覧">
  <main>
    <div class="container">
      <h1>制作ログ</h1>
      <div class="grid">
        {posts.map((post: any) => (
          <article class="post-card">
            <a href={`/blog/${post.id}`}>
              {post.eyecatch && (
                <img src={post.eyecatch.url} alt={post.title} class="eyecatch" />
              )}
              <h2>{post.title}</h2>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .container { max-width: 800px; margin: 0 auto; padding: 2rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem; margin-top: 2rem; }
  .post-card { border: 1px solid #eee; border-radius: 8px; overflow: hidden; transition: transform 0.2s; }
  .post-card:hover { transform: translateY(-5px); }
  .eyecatch { width: 100%; height: 150px; object-fit: cover; }
  h2 { font-size: 1.1rem; padding: 1rem; margin: 0; }
  a { text-decoration: none; color: inherit; }
</style>
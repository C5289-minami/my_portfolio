---
import { client } from "../../lib/microcms";

export async function getStaticPaths() {
  const response = await client.get({ endpoint: "blog" });
  return response.contents.map((post: any) => ({
    params: { id: post.id },
  }));
}

const { id } = Astro.params;
const post = await client.get({ endpoint: "blog", contentId: id });
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>{post.title}</title>
  <style>
    body { font-family: sans-serif; line-height: 1.6; color: #333; max-width: 800px; margin: 0 auto; padding: 2rem; }
    img { max-width: 100%; height: auto; border-radius: 8px; }
  </style>
</head>
<body>
  <a href="/blog">← 記事一覧へ戻る</a>
  <h1>{post.title}</h1>
  <hr>
  <div set:html={post.content} />
</body>
</html>
---
import Layout from '../../layouts/Layout.astro';
import { client } from "../../lib/microcms";

// 1. 全ての記事のIDを取得して、ページを作る準備
export async function getStaticPaths() {
  const response = await client.get({ endpoint: "blog" });
  return response.contents.map((post: any) => ({
    params: { id: post.id },
  }));
}

// 2. その記事のデータを取ってくる
const { id } = Astro.params;
const post = await client.get({ endpoint: "blog", contentId: id });
---

<Layout title={post.title}>
  <main style="max-width: 700px; margin: 0 auto; padding: 2rem;">
    <h1>{post.title}</h1>
    <div set:html={post.content} />
  </main>
</Layout>
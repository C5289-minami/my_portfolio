---
import Layout from '../layouts/Layout.astro';
import { client } from "../../lib/microcms";

// 1. 全ての記事のIDを取得して、ページを自動生成する準備
export async function getStaticPaths() {
  const response = await client.get({ endpoint: "blog" });
  return response.contents.map((post: any) => ({
    params: { id: post.id },
  }));
}

// 2. 特定の記事のデータを取得
const { id } = Astro.params;
const post = await client.get({ endpoint: "blog", contentId: id });
---

<Layout title={post.title}>
  <main class="post-container">
    <img src={post.eyecatch?.url} alt="" class="main-eyecatch" />
    <h1>{post.title}</h1>
    <hr />
    <div class="content" set:html={post.content} />
    <footer class="back-link">
      <a href="/blog">← 一覧に戻る</a>
    </footer>
  </main>
</Layout>

<style>
  .post-container { max-width: 700px; margin: 0 auto; padding: 2rem; line-height: 1.8; }
  .main-eyecatch { width: 100%; height: 300px; object-fit: cover; border-radius: 12px; }
  h1 { margin: 1.5rem 0; font-size: 2rem; }
  .content :global(img) { max-width: 100%; height: auto; border-radius: 8px; }
  .content :global(h2) { margin-top: 2rem; border-left: 4px solid #333; padding-left: 1rem; }
  .back-link { margin-top: 4rem; border-top: 1px solid #eee; padding-top: 1rem; }
</style>